rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // 👤 USER PROFILE PHOTOS
    match /users/{userId}/profile.jpg {
      allow read: if request.auth != null; // Everyone can see profiles
      allow write: if request.auth != null && request.auth.uid == userId; // Only owner can change photo
    }
    
    // 📜 JAKIM VERIFICATION DOCUMENTS (Ultra Private)
    match /users/{userId}/verifications/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId; 
      // Strictly owner-only. Not even matches can see these raw docs.
    }
    
    // 🛡️ WALI AVATARS
    match /walis/{waliId}/avatar.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == waliId;
    }
  }
}
